{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "build/infection-log.txt"
    },
    "tmpDir": "build/infection",
    "minMsi": 100,
    "minCoveredMsi": 100,
    "mutators": {
        "@default": true,
        "CastString": {
            "ignoreSourceCodeByRegex": [".*\\(string\\) preg_replace.*"]
        }
    }
}
